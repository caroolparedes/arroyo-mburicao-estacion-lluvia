hardware/**/gerbers/
hardware/**/fab/
hardware/**/*.gbr
hardware/**/*.drl
hardware/**/*.gbl
hardware/**/*.gtl
hardware/**/*.gbs
hardware/**/*.gts
hardware/**/*.gbo
hardware/**/*.gto
hardware/**/*.gm1
hardware/**/*-NPTH.drl

# Archivos de BOM generados automáticamente (si los exportás desde KiCad)
hardware/**/*-BOM.csv
hardware/**/*_bom.xml

# ==========================================
# FreeCAD / Mechanical (archivos temporales)
# ==========================================
*.FCStd1
*.FCBak
mechanical/**/*.FCStd1
mechanical/**/*.FCBak

# ==========================================
# PlatformIO - adicionales
# ==========================================
# Carpeta de librerías descargadas automáticamente
.pio/
firmware/lib/

# ==========================================
# Datos / Logs de campo (si los generás localmente)
# ==========================================
data/
logs/
*.csv
*.log
*.dat

# ==========================================
# Jupyter Notebooks (si usás para análisis)
# ==========================================
.ipynb_checkpoints/
*.ipynb

